// BACKTEST EXECUTOR — Runs filter comparisons on historical data
// ═══════════════════════════════════════════════════════════════

async function executeBacktest(client, params, meetingId) {
  const tfMap = { '1m': 1, '1h': 60, '1d': 1440, 'all': null };
  const lookbackDays = params.lookback_days || 7;
  const barMinutes = tfMap[params.timeframe] || null;

  console.log(`  [Backtest] Running: ${params.description || 'comparison'} (${lookbackDays}d lookback, ${params.timeframe || 'all'} signals)`);

  // Get historical closed signals
  let query = `
    SELECT s.id, s.symbol, s.direction, s."entryPrice", s."exitPrice",
           s."returnPct", s.status, s."createdAt", s."closedAt",
           s."holdBars", st."barMinutes"
    FROM "FracmapSignal" s
    JOIN "FracmapStrategy" st ON s."strategyId" = st.id
    WHERE s.status = 'closed' AND s."returnPct" IS NOT NULL
      AND s."createdAt" > now() - interval '${lookbackDays} days'
  `;
  if (barMinutes) query += ` AND st."barMinutes" = ${barMinutes}`;
  query += ` ORDER BY s."createdAt"`;

  const { rows: signals } = await client.query(query);
  if (signals.length === 0) {
    const result = { error: 'No signals found for the given parameters', signals_count: 0 };
    await client.query(
      `UPDATE board_requests SET status = 'completed', completed_at = now(), result = $1, 
              result_summary = 'No signals found' WHERE meeting_id = $2 AND status = 'pending'`,
      [JSON.stringify(result), meetingId]
    );
    return result;
  }

  // Compute baseline stats (all signals, no filter)
  const computeStats = (sigs) => {
    if (sigs.length === 0) return { count: 0, avgReturn: 0, totalReturn: 0, winRate: 0, sharpe: 0, wins: 0, losses: 0, bestTrade: 0, worstTrade: 0 };
    const rets = sigs.map(s => parseFloat(s.returnPct) || 0);
    const wins = rets.filter(r => r > 0).length;
    const total = rets.reduce((a, b) => a + b, 0);
    const mean = total / rets.length;
    const std = rets.length > 1 ? Math.sqrt(rets.reduce((a, r) => a + (r - mean) ** 2, 0) / rets.length) : 0;
    return {
      count: sigs.length, avgReturn: mean, totalReturn: total,
      winRate: (wins / sigs.length) * 100, wins, losses: sigs.length - wins,
      sharpe: std > 0 ? (mean / std) * Math.sqrt(252) : 0,
      bestTrade: Math.max(...rets), worstTrade: Math.min(...rets),
    };
  };

  const baseline = computeStats(signals);

  // If filter_a is specified, simulate applying it
  const simulateFilter = (sigs, filterDef) => {
    if (!filterDef) return { passed: sigs, blocked: [] };
    const passed = [], blocked = [];
    for (const sig of sigs) {
      let block = false;
      if (filterDef.rules) {
        for (const rule of filterDef.rules) {
          if (rule.direction && sig.direction !== rule.direction) continue;
          // For backtesting we can only use signal-level data, not regime snapshots
          // So we test against available signal fields
          if (rule.feature === 'holdBars' && sig.holdBars) {
            if (rule.min !== undefined && sig.holdBars < rule.min) { block = true; break; }
            if (rule.max !== undefined && sig.holdBars > rule.max) { block = true; break; }
          }
        }
      }
      // Simple return-based simulation for proposed filters
      if (filterDef.min_return !== undefined && (parseFloat(sig.returnPct) || 0) < filterDef.min_return) block = true;
      if (block) blocked.push(sig); else passed.push(sig);
    }
    return { passed, blocked };
  };

  const resultA = params.filter_a ? simulateFilter(signals, params.filter_a) : null;
  const resultB = params.filter_b ? simulateFilter(signals, params.filter_b) : null;

  const result = {
    description: params.description,
    timeframe: params.timeframe || 'all',
    lookback_days: lookbackDays,
    total_signals: signals.length,
    baseline,
    filter_a: resultA ? {
      definition: params.filter_a,
      passed: computeStats(resultA.passed),
      blocked: computeStats(resultA.blocked),
    } : null,
    filter_b: resultB ? {
      definition: params.filter_b,
      passed: computeStats(resultB.passed),
      blocked: computeStats(resultB.blocked),
    } : null,
    // Per-day breakdown
    daily_breakdown: (() => {
      const byDay = {};
      for (const s of signals) {
        const day = new Date(s.createdAt).toISOString().split('T')[0];
        if (!byDay[day]) byDay[day] = [];
        byDay[day].push(s);
      }
      return Object.entries(byDay).map(([day, sigs]) => ({
        date: day,
        ...computeStats(sigs),
      })).sort((a, b) => a.date.localeCompare(b.date));
    })(),
  };

  // Format human-readable summary
  let summary = `📊 BACKTEST RESULTS: ${params.description || 'Filter comparison'}\n`;
  summary += `Period: ${lookbackDays}d · ${signals.length} ${(params.timeframe || 'all').toUpperCase()} signals\n`;
  summary += `Baseline: ${baseline.totalReturn.toFixed(2)}% cum, WR ${baseline.winRate.toFixed(1)}%, SR ${baseline.sharpe.toFixed(2)}\n`;
  if (resultA) {
    const ps = computeStats(resultA.passed);
    const bs = computeStats(resultA.blocked);
    summary += `Filter A: ${resultA.passed.length} pass / ${resultA.blocked.length} blocked → passed ${ps.totalReturn.toFixed(2)}% (SR ${ps.sharpe.toFixed(2)}), blocked avg ${bs.avgReturn.toFixed(3)}%\n`;
  }
  if (resultB) {
    const ps = computeStats(resultB.passed);
    const bs = computeStats(resultB.blocked);
    summary += `Filter B: ${resultB.passed.length} pass / ${resultB.blocked.length} blocked → passed ${ps.totalReturn.toFixed(2)}% (SR ${ps.sharpe.toFixed(2)}), blocked avg ${bs.avgReturn.toFixed(3)}%\n`;
  }

  await client.query(
    `UPDATE board_requests SET status = 'completed', completed_at = now(), result = $1, result_summary = $2
     WHERE meeting_id = $3 AND status = 'pending'`,
    [JSON.stringify(result), summary, meetingId]
  );

  console.log(`  [Backtest] Complete: ${signals.length} signals, baseline SR ${baseline.sharpe.toFixed(2)}`);
  return result;
}


