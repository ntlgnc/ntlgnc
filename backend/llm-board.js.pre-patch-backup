// DEPLOY — Execute a passed motion (with safety guardrails)
// ═══════════════════════════════════════════════════════════════

// Major coins that require supermajority (4/5) AND human approval to exclude
const PROTECTED_COINS = ['BTCUSDT', 'ETHUSDT', 'SOLUSDT', 'BNBUSDT', 'XRPUSDT', 'ADAUSDT', 'DOGEUSDT', 'AVAXUSDT', 'DOTUSDT', 'LINKUSDT'];

// Actions that require human approval before deployment
const REQUIRES_HUMAN_APPROVAL = ['EXCLUDE_COIN', 'INCLUDE_COIN', 'EMERGENCY_HALT', 'STRATEGY_PARAMETER'];

async function deployMotion(client, motion, chairId, meetingId, roundNumber) {
  const type = motion.type;
  const details = motion.details || {};
  
  // Check if this action requires human approval
  if (REQUIRES_HUMAN_APPROVAL.includes(type)) {
    // Queue for human approval instead of deploying
    await client.query(
      `INSERT INTO board_requests (meeting_id, request_type, description, parameters, status)
       VALUES ($1, $2, $3, $4, 'pending_approval')`,
      [meetingId, type, motion.title || `${type}: ${JSON.stringify(details).slice(0, 200)}`,
       JSON.stringify({ motion, details, chairId, votes_for: motion._supportCount, votes_total: motion._totalVotes })]
    );
    console.log(`  ⏸ ${type} queued for HUMAN APPROVAL — will not auto-deploy`);
    console.log(`    Reason: ${type} is a protected action that requires manual confirmation`);
    return false; // Not deployed — pending approval
  }
  
  switch (type) {
    case 'ADD_REGIME_FILTER': {
      const tf = details.timeframe || 'all';
      await client.query(
        `INSERT INTO board_filters (filter_type, feature, conditions, rationale, proposed_by, meeting_id, timeframe)
         VALUES ('regime', $1, $2, $3, $4, $5, $6)`,
        [details.feature || 'unknown', JSON.stringify(details), motion.hypothesis || motion.title, chairId, meetingId, tf]
      );
      console.log(`  ✅ Filter deployed: ${details.feature} [${tf.toUpperCase()} signals]`);
      return true;
    }
    case 'REMOVE_REGIME_FILTER': {
      if (details.filter_id) {
        await client.query(`UPDATE board_filters SET active = false, updated_at = now() WHERE id = $1`, [details.filter_id]);
        console.log(`  ✅ Filter removed: #${details.filter_id}`);
        return true;
      }
      return false;
    }
    case 'EXCLUDE_COIN': {
      if (details.symbol) {
        await client.query(
          `INSERT INTO board_coin_overrides (symbol, override_type, parameters, rationale, meeting_id)
           VALUES ($1, 'exclude', $2, $3, $4)`,
          [details.symbol, JSON.stringify({ excluded: true }), motion.hypothesis, meetingId]
        );
        console.log(`  ✅ Coin excluded: ${details.symbol}`);
        return true;
      }
      return false;
    }
    case 'INCLUDE_COIN': {
      if (details.symbol) {
        await client.query(
          `UPDATE board_coin_overrides SET active = false WHERE symbol = $1 AND override_type = 'exclude' AND active = true`,
          [details.symbol]
        );
        console.log(`  ✅ Coin re-included: ${details.symbol}`);
        return true;
      }
      return false;
    }
    case 'NEW_REGIME_FEATURE': {
      await client.query(
        `INSERT INTO board_research_log (research_type, hypothesis, methodology, result, meeting_id)
         VALUES ('new_feature', $1, $2, $3, $4)`,
        [motion.hypothesis, JSON.stringify(details), JSON.stringify({ status: 'proposed' }), meetingId]
      );
      console.log(`  ✅ Research initiated: ${details.feature_name || 'new feature'}`);
      return true;
    }
    case 'KILL_RESEARCH': {
      await client.query(
        `INSERT INTO board_research_log (research_type, hypothesis, conclusion, status, killed_by, killed_reason, meeting_id)
         VALUES ('killed', $1, 'Killed by board vote', 'killed', $2, $3, $4)`,
        [details.research_line, chairId, details.evidence, meetingId]
      );
      console.log(`  ✅ Research killed: ${details.research_line}`);
      return true;
    }
    case 'REQUEST_BACKTEST':
    case 'REQUEST_ANALYSIS': {
      await client.query(
        `INSERT INTO board_requests (meeting_id, request_type, description, parameters, status)
         VALUES ($1, $2, $3, $4, 'pending')`,
        [meetingId, type, motion.title || details.description || 'Board request',
         JSON.stringify(details)]
      );
      console.log(`  📊 ${type === 'REQUEST_BACKTEST' ? 'Backtest' : 'Analysis'} queued: ${motion.title || details.description}`);
      // Execute immediately
      try {
        await executeBacktest(client, details, meetingId);
      } catch (err) {
        console.warn(`  ⚠ Backtest execution failed: ${err.message}`);
      }
      return true;
    }
    case 'AFFIRM_PATIENCE': {
      console.log(`  ✅ PATIENCE AFFIRMED: ${details.rationale || motion.title}`);
      // No system changes — this is a formal "do nothing" vote
      return true;
    }
    case 'EDIT_HERO': {
      const d = details;
      // Enforce character limits
