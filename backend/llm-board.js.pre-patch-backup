// MEETING ENGINE — 8-Phase Protocol
// ═══════════════════════════════════════════════════════════════

async function runBoardMeeting() {
  const meetingStart = Date.now();
  const client = await pool.connect();
  
  try {
    await ensureTables(client);
    
    // DEDUP GUARD: Skip if a meeting completed or started within the last 30 minutes
    // (bypassed for manual triggers)
    if (!manualTrigger) {
      const { rows: recentMeetings } = await client.query(
        `SELECT id, round_number, phase, created_at FROM board_meetings 
         WHERE created_at > now() - interval '30 minutes' 
         ORDER BY created_at DESC LIMIT 1`
      );
      if (recentMeetings.length > 0) {
        const minutesAgo = (Date.now() - new Date(recentMeetings[0].created_at).getTime()) / 60000;
        console.log(`[board] ⏭ Skipping — meeting #${recentMeetings[0].round_number} (${recentMeetings[0].phase}) ran ${minutesAgo.toFixed(0)}min ago. Next meeting after 30min gap.`);
        return { skipped: true, reason: `Meeting #${recentMeetings[0].round_number} ran ${minutesAgo.toFixed(0)}min ago` };
      }
    } else {
      console.log(`[board] ⚡ Manual trigger — skipping dedup guard`);
    }
    
    const { rows: lastMeeting } = await client.query(
      `SELECT round_number FROM board_meetings ORDER BY round_number DESC LIMIT 1`
    );
    const roundNumber = (lastMeeting[0]?.round_number || 0) + 1;
    const chairIdx = (roundNumber - 1) % BOARD_MEMBERS.length;
    const chair = BOARD_MEMBERS[chairIdx];
    const otherMembers = BOARD_MEMBERS.filter(m => m.id !== chair.id);
    
    console.log(`\n${'═'.repeat(70)}`);
    console.log(`  BOARD MEETING #${roundNumber} — Chair: ${chair.name} (${chair.role})`);
    console.log(`  ${new Date().toISOString()}`);
    console.log(`${'═'.repeat(70)}\n`);
    
    // Build context
    let context, briefingText;
    try {
      context = await buildMeetingContext(client);
      briefingText = formatBriefing(context);
    } catch (ctxErr) {
      console.error(`[board] ❌ Context/briefing build failed:`, ctxErr.message, ctxErr.stack);
      // Update meeting as failed
      try {
        await client.query(
          `UPDATE board_meetings SET phase = 'failed', decision = $1, duration_ms = $2 WHERE round_number = $3`,
          [`Context build error: ${ctxErr.message}`, Date.now() - meetingStart, roundNumber]
        );
      } catch {}
      return { error: `Context build failed: ${ctxErr.message}` };
    }
    
    // Log briefing excerpt so we can verify data flow
    console.log(`\n── BRIEFING EXCERPT ──`);
    console.log(briefingText.slice(0, 1500));
    console.log(`── (${briefingText.length} chars total) ──\n`);
    
    // Create meeting record (store briefing text, not full context object — avoids serialization issues)
    let meetingId;
    try {
      const { rows: [meeting] } = await client.query(
        `INSERT INTO board_meetings (round_number, chair_id, phase, context)
         VALUES ($1, $2, 'started', $3) RETURNING id`,
        [roundNumber, chair.id, JSON.stringify({ briefingLength: briefingText.length, timestamp: context.timestamp })]
      );
      meetingId = meeting.id;
    } catch (insertErr) {
      console.error(`[board] ❌ Failed to create meeting row:`, insertErr.message);
      return { error: `Meeting insert failed: ${insertErr.message}` };
    }
    let totalTokens = 0;

    // Build the system prompt (genesis + personality)
    const memberSystem = (m) => `${GENESIS_DOCUMENT}\n\nYOUR ROLE: ${m.name} — ${m.role}\n${m.personality}\n\nYou are in Board Meeting #${roundNumber}. Respond with valid JSON only.`;

    // ─── PHASE 1: SITUATIONAL AWARENESS (Chair) ───
    console.log(`[Phase 1] ${chair.name} reviews situation...\n`);
    
    const p1Resp = await callLLM(chair, memberSystem(chair), `
You are chairing this meeting. Here is the full briefing:

${briefingText}

PHASE 1 — SITUATIONAL AWARENESS. Summarise the key points in 3-5 sentences.
Focus on: data maturity status, any filters approaching decision-readiness,
regime conditions, and what changed since last meeting.

CRITICAL: Check the maturity scores FIRST. If no filters are decision-ready,
note this prominently — the board's main job may be patience, research, or creative work.

Respond as JSON:
{
  "situation_summary": "Your 3-5 sentence summary",
  "key_changes": ["change 1", "change 2", ...],
  "concerning_patterns": ["pattern 1", ...],
  "data_maturity_note": "Summary of which filters are/aren't decision-ready",
  "recommended_focus": "filters|research|competition|patience|creative"
}`, 800);
    totalTokens += p1Resp.tokens;
    const p1 = parseJSON(p1Resp.text) || { situation_summary: p1Resp.text };
    console.log(`  Summary: ${(p1.situation_summary || '').slice(0, 200)}...\n`);

    // ─── PHASE 2: PROBLEM IDENTIFICATION (All members) ───
    console.log(`[Phase 2] All members identify problems...\n`);
    
    const problemPromises = otherMembers.map(m => callLLM(m, memberSystem(m), `
CHAIR'S SITUATION SUMMARY: ${p1.situation_summary || p1Resp.text}

KEY CHANGES: ${JSON.stringify(p1.key_changes || [])}

FULL BRIEFING DATA:
${briefingText}

PHASE 2 — PROBLEM IDENTIFICATION. As ${m.name} (${m.role}), identify 1-3 problems.

BEFORE IDENTIFYING PROBLEMS: Check the maturity status of all active filters.
If no filter has reached 2000+ evaluated signals AND 72+ hours, the correct
answer may be "insufficient data to evaluate our existing decisions."
This is a VALID and IMPORTANT problem that can lead to AFFIRM_PATIENCE.

Consider problems in ALL areas: filters, research gaps, competition opportunities,
hero section, BTC forecast accuracy, signal volume, regime analysis.

You may also request topics for future meetings.

Respond as JSON:
{
  "problems": [
    { "title": "Short name", "severity": "HIGH/MEDIUM/LOW", "evidence": "Data supporting this is a problem" }
  ],
  "requested_topics": [
    { "topic": "Topic for future meeting", "rationale": "Why this matters", "priority": "HIGH/NORMAL/LOW" }
  ]
}`, 500));
    
    const problemResponses = await Promise.all(problemPromises);
    const allProblems = [];
    const allTopicRequests = [];
    for (let i = 0; i < otherMembers.length; i++) {
      totalTokens += problemResponses[i].tokens;
      const parsed = parseJSON(problemResponses[i].text);
      const problems = parsed?.problems || [{ title: problemResponses[i].text.slice(0, 100), severity: 'MEDIUM', evidence: '' }];
      for (const p of problems) {
        allProblems.push({ ...p, identified_by: otherMembers[i].id });
      }
      // Collect topic requests
      if (parsed?.requested_topics) {
        for (const t of parsed.requested_topics) {
          allTopicRequests.push({ ...t, requested_by: otherMembers[i].id });
        }
      }
      console.log(`  ${otherMembers[i].name}: ${problems.map(p => p.title).join(', ')}`);
      if (parsed?.requested_topics?.length) {
        console.log(`    📋 Topics: ${parsed.requested_topics.map(t => t.topic).join(', ')}`);
      }
    }
    console.log();

    // ─── PHASE 3: PROBLEM PRIORITISATION (Chair) ───
    console.log(`[Phase 3] ${chair.name} selects the key problem...\n`);
    
    const p3Resp = await callLLM(chair, memberSystem(chair), `
ALL IDENTIFIED PROBLEMS:
${JSON.stringify(allProblems, null, 2)}

${allTopicRequests.length > 0 ? `NEW TOPIC REQUESTS FROM THIS MEETING:\n${JSON.stringify(allTopicRequests, null, 2)}\n` : ''}
${(context.meetingChain?.topicRequests || []).length > 0 ? `PENDING TOPIC REQUESTS FROM PREVIOUS MEETINGS:\n${JSON.stringify(context.meetingChain.topicRequests, null, 2)}\n` : ''}

PHASE 3 — PRIORITISATION. You must select THE SINGLE MOST IMPORTANT problem
to address this meeting. Consider severity, urgency, and data support.
You may also select a pending topic request if it's more urgent than new problems.

Respond as JSON:
{
  "selected_problem": "Title of the chosen problem",
  "rationale": "Why this is the most important one to address now",
  "deferred": ["Problem titles that can wait"]
}`, 500);
    totalTokens += p3Resp.tokens;
    const p3 = parseJSON(p3Resp.text) || { selected_problem: allProblems[0]?.title || 'No problems identified' };
    console.log(`  Selected: ${p3.selected_problem}\n`);

    // ─── PHASE 4: SOLUTION DISCUSSION (All members) ───
    console.log(`[Phase 4] All members propose solutions...\n`);
    
    const solutionPromises = BOARD_MEMBERS.map(m => callLLM(m, memberSystem(m), `
THE PROBLEM TO SOLVE: ${p3.selected_problem}
Rationale: ${p3.rationale || ''}

CONTEXT:
${briefingText.slice(0, 6000)}

PHASE 4 — SOLUTION DISCUSSION. As ${m.name} (${m.role}), propose your solution.
AVAILABLE MOTION TYPES (pick the most appropriate):
  • ADD_REGIME_FILTER / REMOVE / MODIFY — For filter changes (only if maturity allows)
  • DEPLOY_COIN_STRATEGY — Create a NEW parallel signal loop for a specific coin (NOT a filter — this ADDS signals). Requires 5/5 UNANIMOUS. Provide symbol, timeframe, rationale with OOS Sharpe/trades/rho evidence. Do NOT include filter_conditions or blocking rules.
  • COIN_NO_ACTION — Mark today's reviewed coin as "no action needed"
  • DEACTIVATE_COIN_STRATEGY — Deactivate an existing coin strategy
  • AFFIRM_PATIENCE — To formally vote to wait and gather more data
  • EDIT_HERO — To update the home page hero section (creative)
  • COMPETITION_ENTRY — To submit a coin pick with novel regime factors
  • REQUEST_BACKTEST / REQUEST_ANALYSIS — For historical analysis
  • NEW_REGIME_FEATURE / KILL_RESEARCH — For research pipeline
  • EXCLUDE_COIN / INCLUDE_COIN — For coin management [needs human approval]

Respond as JSON:
{
  "solution": "Your proposed solution in plain English",
  "motion_type": "One of the types above",
  "implementation": { "feature": "...", "conditions": {}, "timeframe": "1h or 1m or 1d or all", "details": "..." },
  "hypothesis": "What you expect this to achieve",
  "success_metric": "How to measure success",
  "concerns": "Any downsides or risks"
}`, 800));
    
    const solutionResponses = await Promise.all(solutionPromises);
    const solutions = [];
    for (let i = 0; i < BOARD_MEMBERS.length; i++) {
      totalTokens += solutionResponses[i].tokens;
      const parsed = parseJSON(solutionResponses[i].text) || { solution: solutionResponses[i].text };
      solutions.push({ member_id: BOARD_MEMBERS[i].id, ...parsed });
      console.log(`  ${BOARD_MEMBERS[i].name}: ${(parsed.solution || '').slice(0, 120)}`);
    }
    console.log();

    // ─── Chair synthesises a single motion from solutions ───
    console.log(`[Phase 4b] ${chair.name} synthesises solutions into one motion...\n`);
    
    const synthesisResp = await callLLM(chair, memberSystem(chair), `
ALL PROPOSED SOLUTIONS:
${JSON.stringify(solutions, null, 2)}

THE PROBLEM: ${p3.selected_problem}

As chair, synthesise the best solution into ONE formal motion for a vote.
Take the strongest ideas and combine them. The motion must be specific and implementable.
IMPORTANT: The motion title MUST include which signal timeframe(s) it applies to (e.g. "1H signals", "1M signals", "All timeframes").

Respond as JSON:
{
  "motion": {
    "title": "Short title including timeframe (e.g. 'Block bottom-range longs on 1H signals')",
    "type": "One of the MOTION_TYPES",
    "details": { "timeframe": "1h or 1m or 1d or all", ... implementation details ... },
    "hypothesis": "Expected outcome",
    "success_metric": "How to measure"
  },
  "rationale": "Why this combines the best ideas"
}`, 1000);
    totalTokens += synthesisResp.tokens;
    const synthesis = parseJSON(synthesisResp.text) || { motion: solutions[0] };
    console.log(`  Motion: ${synthesis.motion?.title || 'Unnamed'}\n`);

    // ─── PHASE 5: VOTE ───
    console.log(`[Phase 5] Voting...\n`);
    
    const votePromises = BOARD_MEMBERS.map(m => callLLM(m, memberSystem(m), `
FORMAL MOTION: ${JSON.stringify(synthesis.motion, null, 2)}

THE PROBLEM: ${p3.selected_problem}
CHAIR'S RATIONALE: ${synthesis.rationale || ''}

PHASE 5 — VOTE. As ${m.name} (${m.role}), cast your vote.

Respond as JSON:
{
  "support": true/false,
  "reasoning": "Why you support or oppose (1-2 sentences)",
  "conditions": "Any conditions for your support (or null)"
}`, 300));

    const voteResponses = await Promise.all(votePromises);
    const votes = {};
    for (let i = 0; i < BOARD_MEMBERS.length; i++) {
      totalTokens += voteResponses[i].tokens;
      const parsed = parseJSON(voteResponses[i].text) || { support: false, reasoning: voteResponses[i].text };
      votes[BOARD_MEMBERS[i].id] = { support: !!parsed.support, role: BOARD_MEMBERS[i].role, reasoning: parsed.reasoning, conditions: parsed.conditions };
      console.log(`  ${BOARD_MEMBERS[i].name}: ${parsed.support ? '✅ SUPPORT' : '❌ OPPOSE'} — ${(parsed.reasoning || '').slice(0, 100)}`);
    }
    
    const supportCount = Object.values(votes).filter(v => v.support).length;
    const totalVotes = Object.values(votes).length;
    const motionType = synthesis.motion?.type || 'UNKNOWN';
    const requiresUnanimous = ['DEPLOY_COIN_STRATEGY'].includes(motionType);
    const requiresSupermajority = ['EMERGENCY_HALT', 'KILL_RESEARCH', 'EXCLUDE_COIN', 'INCLUDE_COIN', 'STRATEGY_PARAMETER'].includes(motionType);
    const threshold = requiresUnanimous ? totalVotes : requiresSupermajority ? Math.ceil(totalVotes * 4 / 5) : Math.ceil(totalVotes / 2 + 0.1);
    const passed = supportCount >= threshold;
    
    if (requiresUnanimous && !passed) {
      console.log(`\n  Result: ${supportCount}/${totalVotes} → ❌ FAILED (needed ${threshold}/${totalVotes} UNANIMOUS for ${motionType})\n`);
    } else if (requiresSupermajority && !passed) {
      console.log(`\n  Result: ${supportCount}/${totalVotes} → ❌ FAILED (needed ${threshold} for supermajority on ${motionType})\n`);
    } else {
      console.log(`\n  Result: ${supportCount}/${totalVotes} → ${passed ? '✅ PASSED' : '❌ FAILED'}\n`);
    }

    const decision = `${passed ? 'PASSED' : 'FAILED'} (${supportCount}/${totalVotes}): ${synthesis.motion?.title || 'Unnamed'}`;

    // ─── PHASE 6: IMPLEMENTATION ───
    let deployed = false;
    if (passed && synthesis.motion) {
      console.log(`[Phase 6] Deploying...\n`);
      try {
        // Attach vote info for the approval queue
        synthesis.motion._supportCount = supportCount;
        synthesis.motion._totalVotes = totalVotes;
        deployed = await deployMotion(client, synthesis.motion, chair.id, meetingId, roundNumber);
      } catch (err) {
        console.error(`  ❌ Deploy error: ${err.message}`);
      }
    }

    // ─── PHASE 7: FOLLOW-UP TARGET ───
    console.log(`[Phase 7] ${chair.name} sets follow-up target...\n`);
    
    const p7Resp = await callLLM(chair, memberSystem(chair), `
Meeting decision: ${decision}
Deployed: ${deployed}
Problem addressed: ${p3.selected_problem}

PHASE 7 — Set a specific, measurable follow-up target for the next meeting.
What should the board check at the start of the next meeting to evaluate
whether this meeting's decision was effective?

Respond as JSON:
{
  "follow_up_target": "Specific measurable target (e.g. 'Check if filtered signal SR > unfiltered SR over the next hour')",
  "how_to_measure": "What data to look at"
}`, 300);
    totalTokens += p7Resp.tokens;
    const p7 = parseJSON(p7Resp.text) || { follow_up_target: 'Review impact at next meeting' };
    console.log(`  Target: ${p7.follow_up_target}\n`);


    // ═══ BTC 60-MINUTE FORECAST (v3) ═══
    console.log(`[BTC Forecast] All members predict BTC direction...\n`);
    
    let btcForecastData = null;
    if (context.btcOhlc.length >= 3) {
      // Build BTC data summary for the LLMs
      const btcBars = context.btcOhlc;
      const lastPrice = parseFloat(btcBars[btcBars.length - 1]?.close || 0);
      const btcSummary = [
        `BTC Current Price: $${lastPrice.toFixed(0)}`,
        `Last 10 bars (1H OHLC):`,
        ...btcBars.slice(-10).map(b => {
          const t = new Date(b.timestamp).toISOString().slice(11, 16);
          return `  ${t}: O${parseFloat(b.open).toFixed(0)} H${parseFloat(b.high).toFixed(0)} L${parseFloat(b.low).toFixed(0)} C${parseFloat(b.close).toFixed(0)}`;
        }),
      ];
      if (context.btcRegime) {
        const r = context.btcRegime;
        btcSummary.push(`BTC Regime: posInRange=${(r.posInRange60||0).toFixed(2)} vol=${r.volState||'?'} atr=${(r.atrCompression||0).toFixed(2)}`);
        btcSummary.push(`  trend=${(r.trend60||0).toFixed(2)} persistence=${(r.persistence60||0).toFixed(2)} hurst=${(r.hurst||0).toFixed(3)} regime=${r.regime||'?'}`);
      }
      if (context.forecastRecord.total > 0) {
        btcSummary.push(`Track record: ${context.forecastRecord.correct}/${context.forecastRecord.total} (${((context.forecastRecord.correct/context.forecastRecord.total)*100).toFixed(0)}%)`);
      }

      const forecastPromises = BOARD_MEMBERS.map(m => callLLM(m, memberSystem(m), `
BTC 60-MINUTE FORECAST. Predict BTC direction for the next hour.

${btcSummary.join('\n')}

You MUST justify your prediction using the regime data above, not gut feeling.
Consider: posInRange (where in the range is BTC?), volatility state, trend, persistence, hurst.

Respond as JSON:
{
  "direction": "UP" or "DOWN",
  "confidence": "LOW" or "MEDIUM" or "HIGH",
  "reasoning": "2-3 sentences citing specific regime values"
}`, 300));

      const forecastResponses = await Promise.all(forecastPromises);
      const forecasts = {};
      let upVotes = 0, downVotes = 0;
      
      for (let i = 0; i < BOARD_MEMBERS.length; i++) {
        totalTokens += forecastResponses[i].tokens;
        const parsed = parseJSON(forecastResponses[i].text) || { direction: 'UP', confidence: 'LOW', reasoning: forecastResponses[i].text };
        const dir = (parsed.direction || '').toUpperCase() === 'DOWN' ? 'DOWN' : 'UP';
        forecasts[BOARD_MEMBERS[i].id] = { direction: dir, confidence: parsed.confidence || 'LOW', reasoning: parsed.reasoning || '' };
        if (dir === 'UP') upVotes++; else downVotes++;
        console.log(`  ${BOARD_MEMBERS[i].name}: ${dir} (${parsed.confidence || 'LOW'}) — ${(parsed.reasoning || '').slice(0, 80)}`);
      }

      const consensus = upVotes >= downVotes ? 'UP' : 'DOWN';
      console.log(`\n  Consensus: ${consensus} (${upVotes} UP / ${downVotes} DOWN)\n`);

      // Save forecast
      try {
        await client.query(`
          INSERT INTO board_btc_forecasts 
            (meeting_id, round_number, btc_price_at_forecast, consensus_direction, individual_forecasts, regime_snapshot)
          VALUES ($1, $2, $3, $4, $5, $6)`,
          [meetingId, roundNumber, lastPrice, consensus, JSON.stringify(forecasts), 
           context.btcRegime ? JSON.stringify(context.btcRegime) : null]
