        try { filterCond = JSON.parse(filterCond); } catch {
          console.log(`  ❌ Coin strategy filter_conditions is not valid JSON`);
          return false;
        }
      }
      const result = await coinStrategyManager.deployCoinStrategy(
        client, 
        { ...d, filter_conditions: filterCond },
        chairId, meetingId,
        `${motion._supportCount || '?'}/${motion._totalVotes || '?'}`
      );
      if (result.success) {
        console.log(`  ✅ Coin strategy deployed: ${result.strategy_name} (FracmapStrategy id=${result.fracmap_strategy_id})`);
        console.log(`  ▶ New parallel signal loop will start within 60 seconds`);
        coinStrategyManager.invalidateCoinStrategyCache();
        return true;
      } else {
        console.log(`  ❌ Coin strategy deployment failed: ${result.error}`);
        return false;
      }
    }
    case 'DEACTIVATE_COIN_STRATEGY': {
      const d = details;
      if (!d.strategy_name) {
        console.log(`  ❌ Deactivate coin strategy missing strategy_name`);
        return false;
      }
      await coinStrategyManager.deactivateCoinStrategy(
        client, d.strategy_name, chairId, d.rationale || motion.hypothesis || 'Board voted to deactivate'
      );
      coinStrategyManager.invalidateCoinStrategyCache();
      console.log(`  ✅ Coin strategy deactivated: ${d.strategy_name}`);
      return true;
    }
    case 'COIN_NO_ACTION': {
      const d = details;
      if (!d.symbol) {
        console.log(`  ❌ Coin no-action missing symbol`);
        return false;
      }
      await coinStrategyManager.markCoinReviewedNoAction(
        client, d.symbol, meetingId
      );
      console.log(`  ✅ Coin ${d.symbol} marked as reviewed — no action needed`);
      return true;
    }
    default: {
      console.log(`  ⏸ ${type} requires manual review`);
      return false;
    }
  }
}


